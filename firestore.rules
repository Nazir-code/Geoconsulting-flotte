rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isManager() {
      return get(/databases/$(database)/documents/drivers/$(request.auth.uid)).data.role in ['manager', 'admin']
          || request.auth.token.email.matches('.*admin.*')
          || request.auth.token.email.matches('.*manager.*');
    }

    // --- Collections ---

    // Collection: Drivers
    match /drivers/{driverId} {
      allow read: if isAuthenticated();

      // Mise à jour :
      //  - le manager peut tout modifier (dont approvalStatus = approuver/refuser) ;
      //  - le chauffeur peut MAJ ses données (GPS, statut…) MAIS PAS son propre
      //    approvalStatus (anti auto-approbation).
      allow update: if isAuthenticated() && (
        isManager() ||
        (isOwner(driverId) &&
         request.resource.data.get('approvalStatus', null) == resource.data.get('approvalStatus', null))
      );

      // Création :
      //  - le manager peut créer n'importe quel profil ;
      //  - le chauffeur ne peut créer QUE son propre profil, et UNIQUEMENT en
      //    'pending' (il ne peut pas s'inscrire déjà approuvé).
      allow create: if isAuthenticated() && (
        isManager() ||
        (isOwner(driverId) && request.resource.data.get('approvalStatus', 'pending') == 'pending')
      );

      // Suppression réservée aux managers.
      allow delete: if isAuthenticated() && isManager();

      // Sous-collection : historique GPS — écrit uniquement par le chauffeur propriétaire
      match /location_history/{historyId} {
        allow read: if isAuthenticated() && (isOwner(driverId) || isManager());
        allow create: if isAuthenticated() && isOwner(driverId);
      }
    }

    // Collection: Missions
    match /missions/{missionId} {
      // Lecture autorisée pour le chauffeur assigné ou les managers.
      // `resource == null` tolère la lecture d'une mission inexistante
      // (supprimée entre-temps) : sans ça, l'évaluation de `resource.data`
      // sur un doc null plante et renvoie permission-denied au lieu de
      // « introuvable », ce qui bloque le chauffeur s'il référence encore
      // une mission supprimée (champ drivers/{uid}.currentMission obsolète).
      allow read: if isAuthenticated() && (resource == null || resource.data.assignedTo == request.auth.uid || isManager());

      // Un chauffeur peut mettre à jour le statut d'une mission qui lui est assignée
      allow update: if isAuthenticated() && (resource.data.assignedTo == request.auth.uid || isManager());

      // Seuls les managers peuvent créer ou supprimer des missions
      allow create, delete: if isAuthenticated() && isManager();
    }

    // Collection: Vehicles
    match /vehicles/{vehicleId} {
      // Lecture pour tout utilisateur authentifié (web + mobile)
      allow read: if isAuthenticated();

      // Création / modification / suppression réservées aux managers
      allow create, update, delete: if isAuthenticated() && isManager();
    }

    // Collection: fuel_records (pleins de carburant)
    match /fuel_records/{recordId} {
      // Lecture pour tout utilisateur authentifié (web + mobile)
      allow read: if isAuthenticated();

      // Saisie par le chauffeur (mobile) OU le manager (web)
      allow create: if isAuthenticated();

      // Modification / suppression réservées aux managers
      allow update, delete: if isAuthenticated() && isManager();
    }

    // Collection: maintenance_requests (demandes d'entretien signalées par le chauffeur)
    match /maintenance_requests/{requestId} {
      // Lecture pour tout utilisateur authentifié (web + mobile)
      allow read: if isAuthenticated();

      // Le chauffeur (mobile) peut créer une demande d'entretien
      allow create: if isAuthenticated();

      // Résolution / suppression réservées aux managers
      allow update, delete: if isAuthenticated() && isManager();
    }

    // Collection: alerts (alertes véhicules générées par le tableau de bord)
    match /alerts/{alertId} {
      // Lecture, création, modification et suppression réservées aux managers/admins.
      // Les alertes sont des données de gestion de flotte — non exposées aux chauffeurs.
      allow read, create, update, delete: if isAuthenticated() && isManager();
    }

    // Sécurité par défaut : Refuser tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
